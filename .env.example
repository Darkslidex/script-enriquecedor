# ── LLM — elegir proveedor ─────────────────────────────────────────────────────
# Opción recomendada: OpenRouter (1 sola key, 300+ modelos, algunos GRATIS)
LITELLM_MODEL=openrouter/meta-llama/llama-3.3-70b-instruct:free
OPENROUTER_API_KEY=sk-or-v1-...

# Alternativas directas
# LITELLM_MODEL=gpt-4o-mini
# OPENAI_API_KEY=sk-...

# LITELLM_MODEL=claude-haiku-4-5-20251001
# ANTHROPIC_API_KEY=sk-ant-...

# LITELLM_MODEL=gemini/gemini-2.5-flash
# GEMINI_API_KEY=...

# LITELLM_MODEL=ollama/llama3.2  (local, sin key)

# ── APIs de enriquecimiento (opcionales) ───────────────────────────────────────
HUNTER_API_KEY=            # validación de emails — hunter.io (25/mes gratis)
GOOGLE_PLACES_KEY=         # discovery de hoteles — console.cloud.google.com

# ── VPS — sincronización con dashboard ────────────────────────────────────────
VPS_SSH_ALIAS=bunker        # alias SSH en ~/.ssh/config
VPS_APP_PATH=/root/apps/barrios-dashboard
VPS_DB_URL=postgresql://...

# ── Comportamiento ─────────────────────────────────────────────────────────────
RATE_LIMIT_SECONDS=3.0
VERBOSE_LOGS=false
