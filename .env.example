# ─── LLM ─────────────────────────────────────────────────────────────────────
# Modelo activo. Opciones: gpt-4o-mini | claude-haiku-4-5 | gemini-2.5-flash | ollama/llama3.1
LITELLM_MODEL=gpt-4o-mini

OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GEMINI_API_KEY=

# ─── APIs de enriquecimiento ──────────────────────────────────────────────────
HUNTER_API_KEY=
GOOGLE_PLACES_KEY=

# ─── VPS / Upload ─────────────────────────────────────────────────────────────
VPS_SSH_ALIAS=bunker
VPS_APP_PATH=/root/apps/barrios-dashboard
VPS_DB_URL=postgresql://barrios_admin:PASSWORD@barrios-db:5432/barrios_db
VPS_DB_PASSWORD=

# ─── Comportamiento opcional ─────────────────────────────────────────────────
# Rate limit por dominio en segundos (default: 3)
RATE_LIMIT_SECONDS=3
# Activar logs verbose sin sanitización PII (solo para debug local)
VERBOSE_LOGS=false
